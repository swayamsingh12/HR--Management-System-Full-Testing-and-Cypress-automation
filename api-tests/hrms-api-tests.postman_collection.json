{
  "info": {
    "name": "HRMS API - CI (Newman)",
    "_postman_id": "c3d4e5f6-0000-4000-9000-hrmsci0000001",
    "description": "CI API suite run by Newman. Folders run top-to-bottom. Setup captures admin/employee tokens and EMP001/EMP002 ids into collection variables. The 'Known Bugs' folder asserts the CORRECT behaviour, so those tests FAIL today (they document BUG-004/006/007) and will pass once the bugs are fixed. baseUrl defaults to http://localhost:5000/api.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "employeeToken", "value": "" },
    { "key": "emp001Id", "value": "" },
    { "key": "emp002Id", "value": "" },
    { "key": "lastPayrollId", "value": "" }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Login - Admin",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('has token', () => pm.expect(b.token).to.be.a('string').and.not.empty);",
            "pm.collectionVariables.set('adminToken', b.token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@hrms.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Employee (asha)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('employeeToken', pm.response.json().token);"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"asha@hrms.com\",\n  \"password\": \"EMP001@123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Capture Employee IDs",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "const list = pm.response.json();",
            "const e1 = list.find(e => e.employeeId === 'EMP001');",
            "const e2 = list.find(e => e.employeeId === 'EMP002');",
            "pm.test('EMP001 exists (seed the DB)', () => pm.expect(e1).to.exist);",
            "if (e1) pm.collectionVariables.set('emp001Id', e1._id);",
            "if (e2) pm.collectionVariables.set('emp002Id', e2._id);"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] }
          }
        }
      ]
    },
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "List Employees (200, array)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "pm.test('is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] }
          }
        },
        {
          "name": "Generate Payroll (201 or 400)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201 created or 400 already-generated', () => pm.expect([201,400]).to.include(pm.response.code));",
            "const b = pm.response.json();",
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('lastPayrollId', b.payroll._id);",
            "  pm.test('gross = basic + hra + allowances', () => pm.expect(b.payroll.salary.gross).to.eql(b.payroll.salary.basic + b.payroll.salary.hra + b.payroll.salary.allowances));",
            "}"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"{{emp001Id}}\",\n  \"month\": 7,\n  \"year\": 2026\n}" },
            "url": { "raw": "{{baseUrl}}/payroll/generate", "host": ["{{baseUrl}}"], "path": ["payroll", "generate"] }
          }
        },
        {
          "name": "All Payrolls (200, array)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "const list = pm.response.json();",
            "pm.test('is array', () => pm.expect(list).to.be.an('array'));",
            "if (Array.isArray(list) && list.length) pm.collectionVariables.set('lastPayrollId', list[0]._id);"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/payroll", "host": ["{{baseUrl}}"], "path": ["payroll"] }
          }
        },
        {
          "name": "Download Payslip (200, PDF)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 200', () => pm.response.to.have.status(200));",
            "pm.test('content-type is PDF', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/payroll/{{lastPayrollId}}/payslip", "host": ["{{baseUrl}}"], "path": ["payroll", "{{lastPayrollId}}", "payslip"] }
          }
        }
      ]
    },
    {
      "name": "Validation",
      "item": [
        {
          "name": "Login missing email (400)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 400', () => pm.response.to.have.status(400));",
            "pm.test('mentions provide email', () => pm.expect(pm.response.json().message).to.match(/provide email/i));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login wrong password (401)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 401', () => pm.response.to.have.status(401));",
            "pm.test('message includes Invalid', () => pm.expect(pm.response.json().message).to.match(/invalid/i));"
          ] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@hrms.com\",\n  \"password\": \"wrong\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Duplicate email (400)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status is 400', () => pm.response.to.have.status(400));",
            "pm.test('message includes already exists', () => pm.expect(pm.response.json().message).to.match(/already exists/i));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Dup\",\n  \"lastName\": \"Email\",\n  \"email\": \"asha@hrms.com\",\n  \"phone\": \"9999999999\",\n  \"dateOfBirth\": \"1995-01-01\",\n  \"dateOfJoining\": \"2024-01-01\",\n  \"department\": \"Engineering\",\n  \"position\": \"Developer\",\n  \"salary\": { \"basic\": 10000 }\n}" },
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] }
          }
        }
      ]
    },
    {
      "name": "Known Bugs (EXPECTED TO FAIL)",
      "description": "These assert the CORRECT behaviour, so they fail on the buggy codebase and document the bugs. They will pass once the bugs are fixed. The CI step that runs Newman uses continue-on-error so these do not turn the whole pipeline red.",
      "item": [
        {
          "name": "BUG-004 - Negative salary should be rejected (expect 400)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const b = pm.response.json();",
            "console.log('BUG-004 actual status:', pm.response.code, '| basic saved:', b.employee && b.employee.salary.basic);",
            "pm.test('BUG-004: negative salary should be rejected with 400', () => pm.response.to.have.status(400));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"basic\": -50000\n}" },
            "url": { "raw": "{{baseUrl}}/admin/employees/{{emp001Id}}/salary", "host": ["{{baseUrl}}"], "path": ["admin", "employees", "{{emp001Id}}", "salary"] }
          }
        },
        {
          "name": "Deactivate EMP002 (setup for BUG-006)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('deactivation request accepted', () => pm.response.to.have.status(200));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"isActive\": false\n}" },
            "url": { "raw": "{{baseUrl}}/admin/employees/{{emp002Id}}/status", "host": ["{{baseUrl}}"], "path": ["admin", "employees", "{{emp002Id}}", "status"] }
          }
        },
        {
          "name": "BUG-006 - Payroll for inactive employee should be blocked (expect 400)",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "const base = Math.floor(Date.now()/1000);",
              "pm.variables.set('bugMonth', (base % 12) + 1);",
              "pm.variables.set('bugYear', 2035 + (base % 40));"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "console.log('BUG-006 actual status:', pm.response.code, '|', pm.response.json().message);",
              "pm.test('BUG-006: payroll should be blocked (400) for inactive employee', () => pm.response.to.have.status(400));",
              "pm.test('BUG-006: message should mention inactive', () => pm.expect(pm.response.json().message || '').to.match(/inactive/i));"
            ] } }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"{{emp002Id}}\",\n  \"month\": {{bugMonth}},\n  \"year\": {{bugYear}}\n}" },
            "url": { "raw": "{{baseUrl}}/payroll/generate", "host": ["{{baseUrl}}"], "path": ["payroll", "generate"] }
          }
        },
        {
          "name": "BUG-007 - Employee must not list all payrolls (expect 403)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const count = Array.isArray(pm.response.json()) ? pm.response.json().length : 0;",
            "console.log('BUG-007 actual status:', pm.response.code, '| records exposed:', count);",
            "pm.test('BUG-007: employee should be forbidden (403) from all payrolls', () => pm.response.to.have.status(403));"
          ] } }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{employeeToken}}", "type": "string" }] },
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/payroll", "host": ["{{baseUrl}}"], "path": ["payroll"] }
          }
        }
      ]
    }
  ]
}
